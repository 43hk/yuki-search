{
  "manifest_version": 3,
  "name": "Yuki Search",
  "description": "A clean anime wallpaper search new tab page.",
  "version": "1.0.0",
  "chrome_url_overrides": {
    "newtab": "src/index.html"
  },
  "host_permissions": [
    "https://suggestqueries.google.com/*",
    "https://api.bing.com/*",
    "https://uapis.cn/*"
  ]
}
